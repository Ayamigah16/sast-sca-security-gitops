# =============================================================================
# Terraform
# =============================================================================

# Local plugin/module cache
**/.terraform/
**/.terraform.lock.hcl

# State files — remote state is in S3; local state only exists in bootstrap
# and still contains sensitive output values, so exclude everywhere
*.tfstate
*.tfstate.backup
crash.log
crash.*.log

# Override files (local developer overrides — never commit)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files with real values — commit only the *.example counterparts
terraform.tfvars
backend.hcl

# Generated Terraform plan files
*.tfplan

# =============================================================================
# Ansible
# =============================================================================

# Generated by Terraform — contains live EC2 IPs and DNS names
infra/ansible/.env
infra/ansible/inventory/hosts.ini

# Vault secrets — vault.yml is encrypted and safe to commit,
# but a decrypted working copy should never be committed
infra/ansible/group_vars/all/vault.yml.decrypted

# Legacy Ansible retry files
*.retry

# =============================================================================
# SSH / TLS private keys
# =============================================================================

# Private/public key pair written by Terraform key_pair module
infra/keys/*.pem
infra/keys/*.pub

# Generic private key patterns
*.key
id_rsa
id_ed25519
id_ecdsa

# =============================================================================
# Python
# =============================================================================

.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Test / coverage artefacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# =============================================================================
# Docker
# =============================================================================
.dockerignore
# Local override compose files
docker-compose.override.yml

# =============================================================================
# Screenshots / evidence images
# =============================================================================

# Keep README placeholders but ignore actual image captures
# screenshots/**/*.png
# screenshots/**/*.jpg
# screenshots/**/*.jpeg
# screenshots/**/*.gif
# screenshots/**/*.mp4

# =============================================================================
# OS / editor artefacts
# =============================================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

.vscode/
.idea/
*.swp
*.swo
*~
.editorconfig.local

# =============================================================================
# Misc
# =============================================================================

*.log
*.tmp
*.bak
.envrc
.direnv/

# =============================================================================
# SonarQube scanner artefacts
# =============================================================================

# Scanner working directory and report task file (created during CI scan)
.sonar/
.scannerwork/
reports/.scannerwork/

# =============================================================================
# CI/CD pipeline runtime artefacts
# =============================================================================

# Rendered ECS task definition and registered ARN — generated per Jenkins build
rendered-task-def.json
task-def-arn.txt

# Security scan reports — archived by Jenkins, not committed to git
reports/

# =============================================================================
# Accidental / stray files
# =============================================================================

# Created by a mis-typed `terraform destroy -auto-approve` command
infra/terraform/aws/troy\ -auto-approve
