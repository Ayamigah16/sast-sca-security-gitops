<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!--
    FALSE POSITIVES: opentelemetry-exporter-otlp-proto-grpc vs grpc/grpc C-core

    OWASP Dependency-Check incorrectly maps the PyPI package
    opentelemetry-exporter-otlp-proto-grpc@1.28.0 to the CPE
    cpe:2.3:a:grpc:grpc:1.28.0 because:
      (a) the package name contains the substring "grpc", and
      (b) the package version (1.28.0) coincides with the old C-core gRPC
          release that carries these CVEs.

    The three CVEs below are all in the C++ / C-core gRPC library
    (https://github.com/grpc/grpc), NOT in the Python opentelemetry
    exporter or the grpcio wheel.  The actual grpcio wheel installed at
    runtime is >= 1.66.0 (see requirements.txt), which is far above the
    fixed releases: CVE-2023-33953 / CVE-2023-4785 fixed in grpcio 1.57.0,
    CVE-2023-44487 fixed in grpcio 1.59.0.

    Reference: https://github.com/jeremylong/DependencyCheck/issues/5973
               (CPE false-positive due to version-number collision)
  -->

  <suppress>
    <notes>
      FP: opentelemetry-exporter-otlp-proto-grpc is not grpc/grpc C-core.
      CVE-2023-44487 (HTTP/2 Rapid Reset) affects C-core grpc &lt; 1.59.0.
      The installed grpcio Python wheel is &gt;= 1.66.0 (see requirements.txt).
    </notes>
    <packageUrl regex="true">^pkg:pypi/opentelemetry[\-\.]exporter[\-\.]otlp[\-\.]proto[\-\.]grpc@.*$</packageUrl>
    <cve>CVE-2023-44487</cve>
  </suppress>

  <suppress>
    <notes>
      FP: opentelemetry-exporter-otlp-proto-grpc is not grpc/grpc C-core.
      CVE-2023-4785 affects C-core grpc &lt;= 1.58.0.
      The installed grpcio Python wheel is &gt;= 1.66.0 (see requirements.txt).
    </notes>
    <packageUrl regex="true">^pkg:pypi/opentelemetry[\-\.]exporter[\-\.]otlp[\-\.]proto[\-\.]grpc@.*$</packageUrl>
    <cve>CVE-2023-4785</cve>
  </suppress>

  <suppress>
    <notes>
      FP: opentelemetry-exporter-otlp-proto-grpc is not grpc/grpc C-core.
      CVE-2023-33953 affects C-core grpc &lt; 1.57.0.
      The installed grpcio Python wheel is &gt;= 1.66.0 (see requirements.txt).
    </notes>
    <packageUrl regex="true">^pkg:pypi/opentelemetry[\-\.]exporter[\-\.]otlp[\-\.]proto[\-\.]grpc@.*$</packageUrl>
    <cve>CVE-2023-33953</cve>
  </suppress>

</suppressions>
